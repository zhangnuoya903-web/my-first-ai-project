{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lygd.example/schemas/customer-schema.json",
  "title": "LYGD CRM 客户对象",
  "description": "客户编号、公司名称、国家、客户类型、联系人、联系方式和历史项目关联。",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "customerId",
    "companyName",
    "customerType",
    "contacts",
    "countryCode",
    "historicalProjectIds",
    "status",
    "versionInfo"
  ],
  "properties": {
    "customerId": {
      "description": "客户唯一编号。",
      "type": "string",
      "minLength": 1
    },
    "companyName": {
      "description": "客户公司正式名称；示例数据必须标记为非真实数据。",
      "type": "string",
      "minLength": 1
    },
    "name": {
      "description": "兼容项目知识库的客户名称别名；建议与 companyName 保持一致。",
      "type": [
        "string",
        "null"
      ]
    },
    "countryCode": {
      "description": "客户所在国家或地区两位代码，对应国家知识库。",
      "type": "string",
      "pattern": "^[A-Z]{2}$"
    },
    "customerType": {
      "description": "客户类型。",
      "type": "string",
      "enum": [
        "owner",
        "contractor",
        "distributor",
        "design-institute",
        "government",
        "other"
      ]
    },
    "contacts": {
      "description": "客户联系人及联系方式列表；公开示例不得包含真实个人信息。",
      "type": "array",
      "items": {
        "description": "单个客户联系人记录。",
        "type": "object",
        "additionalProperties": false,
        "required": [
          "contactId",
          "name",
          "role",
          "phone",
          "email",
          "wechat",
          "whatsapp",
          "isPrimary",
          "remark"
        ],
        "properties": {
          "contactId": {
            "description": "联系人唯一编号。",
            "type": "string",
            "minLength": 1
          },
          "name": {
            "description": "联系人姓名；未知时为 null。",
            "type": [
              "string",
              "null"
            ]
          },
          "role": {
            "description": "联系人角色或职务；未知时为 null。",
            "type": [
              "string",
              "null"
            ]
          },
          "phone": {
            "description": "联系电话；未知时为 null。",
            "type": [
              "string",
              "null"
            ]
          },
          "email": {
            "description": "联系邮箱；未知时为 null。",
            "type": [
              "string",
              "null"
            ],
            "format": "email"
          },
          "wechat": {
            "description": "微信联系方式；未知时为 null。",
            "type": [
              "string",
              "null"
            ]
          },
          "whatsapp": {
            "description": "WhatsApp 联系方式；未知时为 null。",
            "type": [
              "string",
              "null"
            ]
          },
          "isPrimary": {
            "description": "是否为该客户的主要联系人。",
            "type": "boolean"
          },
          "remark": {
            "description": "联系人备注；未知时为 null。",
            "type": [
              "string",
              "null"
            ]
          }
        }
      }
    },
    "historicalProjectIds": {
      "description": "与客户关联的历史项目编号列表。",
      "type": "array",
      "uniqueItems": true,
      "items": {
        "description": "历史项目唯一编号。",
        "type": "string",
        "minLength": 1
      }
    },
    "status": {
      "description": "客户记录状态。",
      "type": "string",
      "enum": [
        "active",
        "inactive",
        "archived"
      ]
    },
    "versionInfo": {
      "description": "客户记录版本信息。",
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schemaVersion",
        "recordVersion",
        "createdAt",
        "updatedAt"
      ],
      "properties": {
        "schemaVersion": {
          "description": "客户 Schema 版本。",
          "type": "string",
          "minLength": 1
        },
        "recordVersion": {
          "description": "客户记录版本号。",
          "type": "integer",
          "minimum": 1
        },
        "createdAt": {
          "description": "客户记录创建时间；模板或未知时为 null。",
          "type": [
            "string",
            "null"
          ],
          "format": "date-time"
        },
        "updatedAt": {
          "description": "客户记录最后更新时间；模板或未知时为 null。",
          "type": [
            "string",
            "null"
          ],
          "format": "date-time"
        }
      }
    }
  }
}
